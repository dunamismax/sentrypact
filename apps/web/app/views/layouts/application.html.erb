<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "SentryPact | Filtering that stays on" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= content_for(:description) || "SentryPact is a lockdown-first blocker with timer-locked Solo Pacts, optional co-signers, tamper detection, and privacy-preserving accountability." %>">
    <meta name="theme-color" content="#080a0a" media="(prefers-color-scheme: dark)">
    <meta name="theme-color" content="#f2eee3" media="(prefers-color-scheme: light)">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="SentryPact">
    <meta name="mobile-web-app-capable" content="yes">
    <meta property="og:site_name" content="SentryPact">
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= content_for(:title) || "SentryPact | Filtering that stays on" %>">
    <meta property="og:description" content="<%= content_for(:description) || "Lockdown-first filtering with timer-locked Solo Pacts, optional co-signers, tamper detection, and privacy-preserving accountability." %>">
    <meta name="twitter:card" content="summary">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <script>
      (() => {
        const theme = localStorage.getItem("sentrypact-theme") || "dark";
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
      })();
    </script>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="antialiased">
    <a href="#main-content" class="skip-link">Skip to content</a>

    <%= render "shared/header" %>

    <main id="main-content">
      <%= yield %>
    </main>

    <%= render "shared/footer" %>
  </body>
</html>
